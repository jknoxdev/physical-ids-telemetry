# L.I.M.A. Firmware Configuration

source "Kconfig.zephyr"

config LIMA_MAIN_LOG_LEVEL
    int "LIMA main log level"
    default 3
    range 0 4

config LIMA_FSM_LOG_LEVEL
    int "LIMA FSM log level"
    default 3
    range 0 4

config LIMA_CRYPTO_LOG_LEVEL
    int "LIMA crypto log level"
    default 3
    range 0 4

config LIMA_DEEP_SLEEP_INTERVAL_MS
    int "Deep sleep wakeup interval (ms)"
    default 6000

config LIMA_BARO_THRESHOLD_PA
    int "Barometric pressure breach threshold in Pascals"
    default 5

config LIMA_CRYPTO_KEY_ID
    hex "PSA persistent key slot ID for LIMA signing key"
    default 0x00000001